    lineHeight: 18,
    paddingHorizontal: 20,
  },
  buttonsContainer: {
    gap: 16,
  },
  roleButton: {
    flexDirection: 'row',
    backgroundColor: '#F5F5F5',
    borderRadius: 16,
    padding: 18,
    alignItems: 'center',
    borderWidth: 1,
    borderColor: '#E5E5E5',

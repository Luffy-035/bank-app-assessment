  },
  filterBtnActive: {
    backgroundColor: '#1601AA',
    borderColor: '#1601AA',
  },
  filterLabel: {
    fontSize: 12,
    fontWeight: '500',
    color: '#6B7280',
  },
  filterLabelActive: {
    color: '#FFFFFF',
  },
  cardsList: {
    paddingHorizontal: 16,
  },
  card: {
    backgroundColor: '#FFFFFF',
    borderRadius: 12,
    marginBottom: 12,
  },
  cardContent: {
    padding: 14,
  },
  cardTop: {
    flexDirection: 'row',
    justifyContent: 'space-between',
    alignItems: 'flex-start',
    marginBottom: 4,
  },
  titleSection: {
    flex: 1,
    marginRight: 10,
  },
  cardTitle: {
    fontSize: 15,
    fontWeight: '700',
    color: '#11181C',
  },
  locationTenant: {
    fontSize: 12,
    color: '#6B7280',
    marginBottom: 12,
  },
  cardDivider: {
    height: 1,
    backgroundColor: '#E5E7EB',

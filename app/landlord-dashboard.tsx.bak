                <Text style={styles.summaryColLabel}>Monthly</Text>
              </View>
              <Text style={styles.summaryColVal}>$8,097</Text>
              <Text style={styles.summaryColSub}>↑ 19.6%  44,714 USD</Text>
            </View>
            <View style={styles.summaryCol}>
              <View style={styles.summaryColHeader}>
                <Ionicons name="calendar-outline" size={12} color="rgba(255,255,255,0.6)" />
                <Text style={styles.summaryColLabel}>Yearly</Text>
              </View>
              <Text style={styles.summaryColVal}>$312,134</Text>
              <Text style={styles.summaryColSub}>↑ 2.6%  301,002 USD</Text>
            </View>
          </View>

          <View style={styles.locList}>
            <View style={styles.locRow}>
              <Text style={styles.locName}>Los Angeles</Text>
              <Text style={styles.locVal}>201,192</Text>
            </View>
            <View style={styles.locRow}>
              <Text style={styles.locName}>New York</Text>

import { FontFamily } from '@/constants/theme';
import { Ionicons } from '@expo/vector-icons';
import { router } from 'expo-router';
import React from 'react';
import {
  Dimensions,
  ScrollView,
  StyleSheet,
  Text,
  TouchableOpacity,
  View,
} from 'react-native';

const { width } = Dimensions.get('window');

export default function LandlordDashboardScreen() {
  return (
    <View style={styles.container}>
      <ScrollView style={styles.scroll} showsVerticalScrollIndicator={false}>
        {/* Header */}
        <View style={styles.header}>
          <View style={styles.headerLeft}>
            <View style={styles.avatar} />
            <View>
              <Text style={styles.welcomeText}>Welcome back,</Text>
              <Text style={styles.userName}>Alex Thompson</Text>
            </View>
          </View>
          <TouchableOpacity>
            <Ionicons name="notifications-outline" size={22} color="#111827" />
          </TouchableOpacity>
        </View>

        {/* Overview */}
        <Text style={styles.sectionTitle}>Overview</Text>

        <View style={styles.overviewCard}>
          {/* Bubble pattern overlay */}
          <View style={styles.bubblePattern}>
            <View style={[styles.bubble, styles.bubble1]} />
            <View style={[styles.bubble, styles.bubble2]} />
            <View style={[styles.bubble, styles.bubble3]} />
          </View>
          <View style={styles.overviewContent}>
            <View style={styles.overviewRow}>
              <View>
                <Text style={styles.overviewLabel}>Total Properties</Text>
                <Text style={styles.overviewSub}>Managed: 12</Text>
              </View>
              <Text style={styles.overviewBig}>20</Text>
            </View>
            <View style={styles.overviewRow2}>
              <Text style={styles.overviewRatio}>10/20</Text>
              <Text style={styles.occupancyText}>Occupancy</Text>
            </View>
            <View style={styles.progressBg}>
              <View style={styles.progressFill} />
            </View>
          </View>
        </View>

        {/* Property Count Badge */}
        <View style={styles.badgeRow}>
          <View style={styles.countBadge}>
            <Text style={styles.countText}>311</Text>
            <Ionicons name="business" size={14} color="#1601AA" />
            <Text style={styles.countText}>171</Text>
          </View>
        </View>

        {/* Stats Grid */}
        <View style={styles.statsGrid}>
          <View style={styles.statCard}>
            <View style={styles.statIconWrap}>
              <Ionicons name="cash" size={20} color="#1601AA" />
            </View>
            <Text style={styles.statValue}>85%</Text>
            <Text style={styles.statLabel}>Rent & Income</Text>
          </View>
          <View style={styles.statCard}>
            <View style={styles.statIconWrap}>
              <Ionicons name="apps" size={20} color="#1601AA" />
            </View>
            <Text style={styles.statValue}>85%</Text>
            <Text style={styles.statLabel}>Tenant Hub</Text>
          </View>
          <View style={styles.statCard}>
            <View style={styles.statIconWrap}>
              <Ionicons name="document-text" size={20} color="#1601AA" />
            </View>
            <Text style={styles.statValue}>92</Text>
            <Text style={styles.statLabel}>Documents</Text>
          </View>
          <View style={styles.statCard}>
            <View style={[styles.statIconWrap, { backgroundColor: '#EDE9FE' }]}>
              <Ionicons name="construct" size={20} color="#7C3AED" />
            </View>
            <Text style={styles.statValue}>05</Text>
            <Text style={styles.statLabel}>Maintenance{'\n'}Request</Text>
          </View>
        </View>

        {/* Tenant Requests */}
        <TouchableOpacity style={styles.tenantCard}>
          <View style={styles.tenantLeft}>
            <View style={styles.tenantIcon}>
              <Ionicons name="person-add-outline" size={18} color="#FFFFFF" />
            </View>
            <View>
              <Text style={styles.tenantLabel}>Tenant Requests</Text>
              <Text style={styles.tenantCount}>03</Text>
            </View>
          </View>
          <Ionicons name="chevron-forward" size={20} color="#FFFFFF" />
        </TouchableOpacity>

        {/* Action Required */}
        <Text style={styles.sectionTitle}>Action Required</Text>

        <TouchableOpacity style={styles.actionCard}>
          <View style={[styles.actionIconWrap, { backgroundColor: '#FEE2E2' }]}>
            <Ionicons name="alert-circle" size={16} color="#DC2626" />
          </View>
          <View style={styles.actionContent}>
            <Text style={styles.actionTitle}>Unit 5B: Rent Overdue</Text>
            <Text style={styles.actionSub}>John Smith is 5 days late.</Text>
          </View>
          <Ionicons name="chevron-forward" size={18} color="#D1D5DB" />
        </TouchableOpacity>

        <TouchableOpacity style={styles.actionCard}>
          <View style={[styles.actionIconWrap, { backgroundColor: '#FEF3C7' }]}>
            <Ionicons name="time-outline" size={16} color="#D97706" />
          </View>
          <View style={styles.actionContent}>
            <Text style={styles.actionTitle}>Lease Ending Soon</Text>
            <Text style={styles.actionSub}>Unit 12A lease expires in 30 days.</Text>
          </View>
          <Ionicons name="chevron-forward" size={18} color="#D1D5DB" />
        </TouchableOpacity>

        {/* Collection */}
        <View style={styles.collectionBox}>
          <Text style={styles.collectionTitle}>Collection</Text>
          <View style={styles.collectionBar}>
            <View style={styles.barGreen} />
            <View style={styles.barRed} />
          </View>
          <View style={styles.collectionRow}>
            <View style={styles.dotWrap}><View style={[styles.dot, { backgroundColor: '#22C55E' }]} /></View>
            <Text style={styles.collectionLabel}>Received</Text>
            <Text style={[styles.collectionVal, { color: '#22C55E' }]}>$18,000</Text>
          </View>
          <View style={styles.collectionRow}>
            <View style={styles.dotWrap}><View style={[styles.dot, { backgroundColor: '#EF4444' }]} /></View>
            <Text style={styles.collectionLabel}>Pending</Text>
            <Text style={[styles.collectionVal, { color: '#EF4444' }]}>$2,000</Text>
          </View>
          <View style={styles.collectionRow}>
            <View style={styles.dotWrap} />
            <Text style={styles.collectionLabel}>Total</Text>
            <Text style={styles.collectionVal}>$20,000</Text>
          </View>
        </View>

        {/* Properties Overview */}
        <View style={styles.sectionHeader}>
          <Text style={styles.sectionTitle2}>Properties Overview</Text>
          <TouchableOpacity><Text style={styles.viewAll}>View All</Text></TouchableOpacity>
        </View>

        <ScrollView horizontal showsHorizontalScrollIndicator={false} contentContainerStyle={styles.propScrollContent}>
          <View style={styles.propCard}>
            <View style={styles.propImg} />
            <View style={styles.propBadge}>
              <Text style={styles.propBadgeText}>Occupied</Text>
            </View>
            <Text style={styles.propName}>Sunset Apartments</Text>
            <Text style={styles.propAddr}>123 Ocean Drive, Miami</Text>
          </View>
          <View style={[styles.propCard, styles.propCardVacant]}>
            <View style={[styles.propImg, { backgroundColor: '#E8E6FA' }]} />
            <View style={[styles.propBadge, { backgroundColor: '#FEF3C7' }]}>
              <Text style={[styles.propBadgeText, { color: '#D97706' }]}>Vacant</Text>
            </View>
            <Text style={styles.propName}>The Grand</Text>
            <Text style={styles.propAddr}>456 Park Ave</Text>
          </View>
        </ScrollView>

        {/* Income Overview */}
        <View style={styles.sectionHeader}>
          <Text style={styles.sectionTitle2}>Income Overview</Text>
          <TouchableOpacity onPress={() => router.push('/rent-income')}><Text style={styles.viewAll}>Full Report</Text></TouchableOpacity>
        </View>

        <View style={styles.incomeCard}>
          <Text style={styles.incomeLabel}>October Total Income</Text>
          <Text style={styles.incomeAmount}>$22,870</Text>
        </View>

        {/* Rental Summary */}
        <View style={styles.rentalCard}>
          <Text style={styles.rentalTitle}>Rental Summary</Text>

          {/* Dotted Arc Chart */}
          <View style={styles.chartWrap}>
            <View style={styles.dotsContainer}>
              {[...Array(13)].map((_, i) => {
                const angle = Math.PI + (i / 12) * Math.PI;
                const x = 60 + 50 * Math.cos(angle);
                const y = 60 + 50 * Math.sin(angle);
                return (
                  <View
                    key={i}
                    style={[
                      styles.chartDot,
                      {
                        left: x - 6,
                        top: y - 6,
                        backgroundColor: i < 9 ? '#6B8CFF' : '#3B5BDB',
                      },
                    ]}
                  />
                );
              })}
            </View>
            <View style={styles.chartIconWrap}>
              <Ionicons name="diamond-outline" size={22} color="#FFFFFF" />
            </View>
          </View>
          <Text style={styles.chartLabel}>Summary</Text>
          <Text style={styles.chartValue}>22,870</Text>

          <View style={styles.summaryRow}>
            <View style={styles.summaryCol}>

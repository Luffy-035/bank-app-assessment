import { FontFamily } from '@/constants/theme';
import { Ionicons } from '@expo/vector-icons';
import { router } from 'expo-router';
import React, { useState } from 'react';
import {
  Dimensions,
  ScrollView,
  StyleSheet,
  Text,
  TouchableOpacity,
  View,
} from 'react-native';
import Svg, { Defs, Line, LinearGradient, Path, Stop } from 'react-native-svg';

const { width } = Dimensions.get('window');

const tabs = [
  { id: 'property', label: 'Property', icon: 'business' },
  { id: 'city', label: 'City', icon: 'location' },
  { id: 'unit', label: 'Unit Type', icon: 'home' },
];

const expenses = [
  { label: 'Maintenance', amount: 4200, color: '#1601AA', width: '100%' },
  { label: 'Utilities', amount: 2800, color: '#1601AA', width: '67%' },
  { label: 'Insurance', amount: 1500, color: '#1601AA', width: '36%' },
  { label: 'Staff', amount: 3200, color: '#9CA3AF', width: '76%' },
  { label: 'Other', amount: 800, color: '#1601AA', width: '19%' },
];

const maintenanceIssues = [
  { icon: 'water-outline', title: 'Plumbing', count: '12 issues this month', trend: 'Ascending', trendColor: '#EF4444', trendBg: '#FEE2E2' },
  { icon: 'flash-outline', title: 'Electrical', count: '8 issues this month', trend: 'Static', trendColor: '#6B7280', trendBg: '#F3F4F6' },
  { icon: 'snow-outline', title: 'HVAC', count: '5 issues this month', trend: 'Descending', trendColor: '#22C55E', trendBg: '#DCFCE7' },
  { icon: 'build-outline', title: 'General Repairs', count: '15 issues this month', trend: 'Ascending', trendColor: '#EF4444', trendBg: '#FEE2E2' },
];

export default function OccupancyScreen() {
  const [activeTab, setActiveTab] = useState('property');

  return (
    <View style={styles.container}>
      {/* Header */}
      <View style={styles.header}>
        <TouchableOpacity onPress={() => router.back()} style={styles.backBtn}>
          <Ionicons name="arrow-back" size={22} color="#111827" />
        </TouchableOpacity>
        <Text style={styles.headerTitle}>Occupancy</Text>
        <View style={{ width: 30 }} />
      </View>

      <ScrollView style={styles.scroll} showsVerticalScrollIndicator={false}>
        {/* Tabs */}
        <View style={styles.tabsRow}>
          {tabs.map((tab) => (
            <TouchableOpacity
              key={tab.id}
              style={[styles.tab, activeTab === tab.id && styles.tabActive]}
              onPress={() => setActiveTab(tab.id)}
            >
              <Ionicons
                name={tab.icon as any}
                size={16}
                color={activeTab === tab.id ? '#FFFFFF' : '#6B7280'}
              />
              <Text style={[styles.tabText, activeTab === tab.id && styles.tabTextActive]}>
                {tab.label}
              </Text>
            </TouchableOpacity>
          ))}
        </View>

        {/* Analytics Overview */}
        <Text style={styles.sectionTitle}>Analytics Overview</Text>

        {/* Occupancy Trend Chart */}
        <View style={styles.chartCard}>
          <Text style={styles.chartTitle}>Occupancy Trend (Last 12 Months)</Text>
          <View style={styles.trendChartContainer}>
            <View style={styles.chartAreaOccupancy}>
              <Svg width={260} height={140} viewBox="0 0 260 140">
                <Defs>
                  <LinearGradient id="occGrad" x1="0" y1="0" x2="0" y2="1">
                    <Stop offset="0%" stopColor="#E7E8FF" stopOpacity="0.9" />
                    <Stop offset="100%" stopColor="#E7E8FF" stopOpacity="0.25" />
                  </LinearGradient>
                </Defs>
                {/* Horizontal grid lines */}
                {[0, 28, 56, 84, 112, 140].map((y, i) => (
                  <Line key={`h${i}`} x1="0" y1={y} x2="260" y2={y} stroke="#E8E8F1" strokeWidth="1" strokeDasharray="3,3" />
                ))}
                {/* Vertical grid lines */}
                {[0, 22, 44, 66, 88, 110, 132, 154, 176, 198, 220, 242, 260].map((x, i) => (
                  <Line key={`v${i}`} x1={x} y1="0" x2={x} y2="140" stroke="#E8E8F1" strokeWidth="1" strokeDasharray="3,3" />
                ))}
                {/* Area fill */}
                <Path
                  d="M 0 70 C 18 66, 34 62, 54 60 C 74 58, 88 56, 106 54 C 124 52, 140 52, 158 54 C 176 56, 190 56, 204 54 C 218 52, 234 42, 260 24 L 260 140 L 0 140 Z"
                  fill="url(#occGrad)"
                />
                {/* Line curve */}
                <Path
                  d="M 0 70 C 18 66, 34 62, 54 60 C 74 58, 88 56, 106 54 C 124 52, 140 52, 158 54 C 176 56, 190 56, 204 54 C 218 52, 234 42, 260 24"
                  stroke="#5D61F6"
                  strokeWidth="2.5"
                  fill="none"
                />
                {/* Points */}
                {[0, 54, 106, 158, 204, 260].map((x, idx) => {
                  const coords = [
                    [0, 70],
                    [54, 60],
                    [106, 54],
                    [158, 54],
                    [204, 54],
                    [260, 24],
                  ][idx];
                  return <Path key={x} d={`M ${coords[0] - 4} ${coords[1]} a4 4 0 1 0 8 0 a4 4 0 1 0 -8 0`} fill="#FFFFFF" stroke="#5D61F6" strokeWidth="2" />;
                })}
              </Svg>
            </View>
          </View>
          <View style={styles.xAxisRow}>
            {['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sept', 'Oct', 'Nov', 'Dec'].map((m) => (
              <Text key={m} style={styles.xLabel}>{m}</Text>
            ))}
          </View>
        </View>

        {/* Expense Tracker */}
        <View style={styles.expenseCard}>
          <Text style={styles.expenseTitle}>Expense Tracker</Text>
          <Text style={styles.expenseTotal}>Total: $12,500</Text>

          {expenses.map((expense, index) => (
            <View key={index} style={styles.expenseRow}>
              <Text style={styles.expenseLabel}>{expense.label}</Text>
              <View style={styles.expenseBarContainer}>
                <View style={[styles.expenseBar, { width: expense.width, backgroundColor: expense.color }]}>
                  <Text style={styles.expenseAmount}>${expense.amount.toLocaleString()}</Text>
                </View>
              </View>
            </View>
          ))}
        </View>

        {/* Frequent Maintenance Issues */}
        <Text style={styles.sectionTitle}>Frequent Maintenance Issues</Text>

        {maintenanceIssues.map((issue, index) => (
          <View key={index} style={styles.issueCard}>
            <View style={styles.issueIconWrap}>
              <Ionicons name={issue.icon as any} size={20} color="#1601AA" />
            </View>
            <View style={styles.issueContent}>
              <Text style={styles.issueTitle}>{issue.title}</Text>
              <Text style={styles.issueCount}>{issue.count}</Text>
            </View>
            <View style={[styles.issueBadge, { backgroundColor: issue.trendBg }]}>
              <Text style={[styles.issueBadgeText, { color: issue.trendColor }]}>{issue.trend}</Text>
            </View>
          </View>
        ))}

        <View style={{ height: 40 }} />
      </ScrollView>
    </View>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1, backgroundColor: '#F3F4F6' },

  // Header
  header: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'space-between',
    backgroundColor: '#FFFFFF',
    paddingTop: 50,
    paddingHorizontal: 16,
    paddingBottom: 16,
    borderBottomWidth: 1,
    borderBottomColor: '#E5E7EB',
  },
  backBtn: { padding: 4 },
  headerTitle: { fontSize: 18, fontFamily: FontFamily.interBold, fontWeight: '700', color: '#111827' },

  scroll: { flex: 1 },

  // Tabs
  tabsRow: {
    flexDirection: 'row',
    paddingHorizontal: 16,
    paddingVertical: 12,
    gap: 8,
  },
  tab: {
    flexDirection: 'row',
    alignItems: 'center',
    paddingHorizontal: 14,
    paddingVertical: 10,
    borderRadius: 8,
    backgroundColor: '#F5F5F7',
    borderWidth: 1,
    borderColor: '#E5E7EB',
    gap: 6,
  },
  tabActive: { backgroundColor: '#4D3CFF', borderColor: '#4D3CFF' },
  tabText: { fontSize: 13, color: '#6B7280', fontWeight: '600' },
  tabTextActive: { color: '#FFFFFF' },

  // Section Title
  sectionTitle: {
    fontSize: 15,
    fontFamily: FontFamily.interBold,
    fontWeight: '700',
    color: '#1F2937',
    paddingHorizontal: 16,
    marginBottom: 10,
    marginTop: 6,
  },

  // Chart Card
  chartCard: {
    backgroundColor: '#FFFFFF',
    marginHorizontal: 16,
    borderRadius: 14,
    padding: 16,
    marginBottom: 16,
    borderWidth: 1,
    borderColor: '#E5E7EB',
  },
  chartTitle: { fontSize: 13, fontFamily: FontFamily.interBold, fontWeight: '700', color: '#111827', marginBottom: 14 },
  trendChartContainer: { flexDirection: 'row', justifyContent: 'center' },
  chartAreaOccupancy: { overflow: 'hidden', width: 260, alignSelf: 'center' },
  xAxisRow: {
    flexDirection: 'row',
    flexWrap: 'wrap',
    justifyContent: 'space-between',
    paddingHorizontal: 12,
    marginTop: 8,
  },
  xLabel: { fontSize: 10, color: '#6B7280', width: (width - 64) / 6.2, textAlign: 'center' },

  // Expense Card
  expenseCard: {
    backgroundColor: '#FFFFFF',
    marginHorizontal: 16,
    borderRadius: 14,
    padding: 16,
    marginBottom: 16,
    borderWidth: 1,
    borderColor: '#E5E7EB',
  },
  expenseTitle: { fontSize: 14, fontFamily: FontFamily.interBold, fontWeight: '700', color: '#111827' },
  expenseTotal: { fontSize: 12, fontFamily: FontFamily.lato, color: '#6B7280', marginTop: 2, marginBottom: 14 },
  expenseRow: {
    flexDirection: 'row',
    alignItems: 'center',
    marginBottom: 12,
  },
  expenseLabel: { width: 90, fontSize: 12, color: '#9CA3AF', textAlign: 'right', marginRight: 12 },
  expenseBarContainer: { flex: 1 },
  expenseBar: {
    height: 28,
    borderRadius: 6,
    justifyContent: 'center',
    alignItems: 'flex-end',
    paddingRight: 10,
  },
  expenseAmount: { fontSize: 12, fontWeight: '600', color: '#FFFFFF' },

  // Issue Card
  issueCard: {
    flexDirection: 'row',
    alignItems: 'center',
    backgroundColor: '#FFFFFF',
    marginHorizontal: 16,
    borderRadius: 12,
    padding: 14,
    marginBottom: 10,
    borderWidth: 1,
    borderColor: '#E5E7EB',
    shadowColor: '#000',
    shadowOffset: { width: 0, height: 6 },
    shadowOpacity: 0.05,
    shadowRadius: 10,
    elevation: 3,
  },
  issueIconWrap: {
    width: 44,
    height: 44,
    borderRadius: 22,
    backgroundColor: '#EEF2FF',
    alignItems: 'center',
    justifyContent: 'center',
    marginRight: 12,
  },
  issueContent: { flex: 1 },
  issueTitle: { fontSize: 14, fontFamily: FontFamily.interSemiBold, fontWeight: '600', color: '#111827' },
  issueCount: { fontSize: 12, fontFamily: FontFamily.lato, color: '#6B7280', marginTop: 2 },
  issueBadge: {
    paddingHorizontal: 12,
    paddingVertical: 6,
    borderRadius: 16,
  },
  issueBadgeText: { fontSize: 12, fontWeight: '500' },
});


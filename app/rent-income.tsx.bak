                <Circle cx="92" cy="26" r="4" fill="#FFFFFF" stroke="#6366F1" strokeWidth="2" />
                <Circle cx="138" cy="24" r="4" fill="#FFFFFF" stroke="#6366F1" strokeWidth="2" />

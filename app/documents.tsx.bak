import { FontFamily } from '@/constants/theme';
import { Ionicons } from '@expo/vector-icons';
import { router } from 'expo-router';
import React, { useState } from 'react';
import {
  ScrollView,
  StyleSheet,
  Text,
  TouchableOpacity,
  View,
} from 'react-native';

type TabType = 'Personal' | 'Property' | 'Legal';

interface Document {
  id: string;
  name: string;
  expiryDate: string;
  status: 'valid' | 'expiring' | 'expired';
  type: 'pdf' | 'image';
}

const documents: Document[] = [
  {
    id: '1',
    name: 'Passport',
    expiryDate: '15 Dec 2024',
    status: 'expiring',
    type: 'pdf',
  },
  {
    id: '2',
    name: "Driver's License",
    expiryDate: '08 Feb 2026',
    status: 'valid',
    type: 'image',
  },
  {
    id: '3',
    name: 'National ID Card',
    expiryDate: '01 Jan 2023',
    status: 'expired',
    type: 'pdf',
  },
];

export default function DocumentsScreen() {
  const [activeTab, setActiveTab] = useState<TabType>('Personal');

  const getStatusColor = (status: Document['status']) => {
    switch (status) {
      case 'valid':
        return '#22C55E';
      case 'expiring':
        return '#F59E0B';
      case 'expired':
        return '#EF4444';
    }
  };

  const getExpiryText = (status: Document['status'], date: string) => {
    if (status === 'expired') {
      return `Expired on: ${date}`;
    }
    return `Expires on: ${date}`;
  };

  const PdfIcon = () => (
    <View style={styles.pdfIconContainer}>
      <View style={styles.pdfDocBody}>
        <View style={styles.pdfFold} />
      </View>
      <Text style={styles.pdfLabel}>PDF</Text>
    </View>
  );

  const ImageIcon = () => (
    <View style={styles.imageIconContainer}>
      <Ionicons name="id-card" size={24} color="#FFFFFF" />
    </View>
  );

  return (
    <View style={styles.container}>
      {/* Header */}
      <View style={styles.header}>
        <TouchableOpacity onPress={() => router.back()} style={styles.backBtn}>
          <Ionicons name="arrow-back" size={22} color="#1F2937" />
        </TouchableOpacity>
        <Text style={styles.headerTitle}>Documents</Text>
        <View style={{ width: 22 }} />
      </View>

      {/* Security Banner */}
      <View style={styles.securityBanner}>
        <Ionicons name="lock-closed" size={14} color="#FFFFFF" />
        <Text style={styles.securityText}>
          Securely store and manage your documents.{'\n'}Your data is encrypted and safe.
        </Text>
      </View>

      {/* Tabs */}
      <View style={styles.tabContainer}>
        {(['Personal', 'Property', 'Legal'] as const).map((tab) => (
          <TouchableOpacity
            key={tab}
            style={styles.tab}
            onPress={() => setActiveTab(tab)}
          >
            <Text style={[styles.tabText, activeTab === tab && styles.tabTextActive]}>
              {tab}
            </Text>
            {activeTab === tab && <View style={styles.tabIndicator} />}
          </TouchableOpacity>
        ))}
      </View>

      {/* Documents List */}
      <ScrollView style={styles.documentsList} showsVerticalScrollIndicator={false}>
        {documents.map((doc, index) => (
          <TouchableOpacity key={doc.id} style={styles.documentCard}>
            {doc.type === 'pdf' ? <PdfIcon /> : <ImageIcon />}
            <View style={styles.docInfo}>
              <Text style={styles.docName}>{doc.name}</Text>
              <Text style={styles.docExpiry}>{getExpiryText(doc.status, doc.expiryDate)}</Text>
            </View>
            <View style={styles.docRight}>
              <View style={[styles.statusDot, { backgroundColor: getStatusColor(doc.status) }]} />
              <Ionicons name="chevron-forward" size={18} color="#D1D5DB" />
            </View>
          </TouchableOpacity>
        ))}
        <View style={{ height: 160 }} />
      </ScrollView>

      {/* Upload Button */}
      <View style={styles.bottomContainer}>
        <TouchableOpacity style={styles.uploadBtn}>
          <Ionicons name="cloud-upload-outline" size={20} color="#FFFFFF" />
          <Text style={styles.uploadBtnText}>Upload New Document</Text>
        </TouchableOpacity>
      </View>
    </View>
  );
}

const styles = StyleSheet.create({
  container: {
    flex: 1,
    backgroundColor: '#FFFFFF',
  },
  header: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'space-between',
    paddingTop: 50,
    paddingBottom: 14,
    paddingHorizontal: 16,
  },
  backBtn: {
    padding: 4,
  },
  headerTitle: {
    fontSize: 17,
    fontFamily: FontFamily.interSemiBold,
    fontWeight: '600',
    color: '#1F2937',
  },
  securityBanner: {
    flexDirection: 'row',
    alignItems: 'center',
    backgroundColor: '#1E3A5F',
    marginHorizontal: 16,
    borderRadius: 10,
    paddingVertical: 12,
    paddingHorizontal: 14,
    gap: 10,
  },
  securityText: {
    flex: 1,
    fontSize: 12,
    fontFamily: FontFamily.lato,
    color: '#FFFFFF',
    lineHeight: 17,
  },
  tabContainer: {
    flexDirection: 'row',
    paddingHorizontal: 16,
    marginTop: 16,
    borderBottomWidth: 1,
    borderBottomColor: '#E5E7EB',
  },
  tab: {
    paddingVertical: 10,
    paddingHorizontal: 16,
    marginRight: 12,
    position: 'relative',
  },
  tabIndicator: {
    position: 'absolute',
    bottom: -1,
    left: 8,
    right: 8,
    height: 2,
    backgroundColor: '#1601AA',
    borderRadius: 1,
  },
  tabText: {
    fontSize: 14,
    fontFamily: FontFamily.lato,
    color: '#9CA3AF',
    fontWeight: '500',
  },
  tabTextActive: {
    color: '#1F2937',
    fontFamily: FontFamily.latoSemiBold,
    fontWeight: '600',
  },
  documentsList: {
    flex: 1,
    paddingHorizontal: 16,
    paddingTop: 8,
  },
  documentCard: {
    flexDirection: 'row',
    alignItems: 'center',
    paddingVertical: 14,
    backgroundColor: '#FFFFFF',
  },
  pdfIconContainer: {
    width: 44,
    height: 52,
    alignItems: 'center',
    justifyContent: 'flex-start',
  },
  pdfDocBody: {
    width: 36,
    height: 42,
    backgroundColor: '#FECACA',
    borderRadius: 4,
    position: 'relative',
    overflow: 'hidden',
  },
  pdfFold: {
    position: 'absolute',
    top: 0,
    right: 0,
    width: 10,
    height: 10,
    backgroundColor: '#EF4444',
    borderBottomLeftRadius: 4,
  },
  pdfLabel: {
    fontSize: 8,
    fontFamily: FontFamily.interBold,
    fontWeight: '700',
    color: '#EF4444',
    marginTop: 2,
  },
  imageIconContainer: {
    width: 44,
    height: 44,
    borderRadius: 8,
    backgroundColor: '#3B82F6',
    alignItems: 'center',
    justifyContent: 'center',
  },
  docInfo: {
    flex: 1,
    marginLeft: 12,
  },
  docName: {
    fontSize: 15,
    fontFamily: FontFamily.interSemiBold,
    fontWeight: '600',
    color: '#1F2937',
    marginBottom: 3,
  },
  docExpiry: {
    fontSize: 12,
    fontFamily: FontFamily.lato,
    color: '#9CA3AF',
  },
  docRight: {
    flexDirection: 'row',
    alignItems: 'center',
    gap: 8,
  },
  statusDot: {
    width: 8,
    height: 8,
    borderRadius: 4,
  },
  bottomContainer: {
    position: 'absolute',
    bottom: 0,
    left: 0,
    right: 0,
    paddingHorizontal: 16,
    paddingBottom: 90,
    paddingTop: 16,
    backgroundColor: '#FFFFFF',
  },
  uploadBtn: {
    flexDirection: 'row',
    alignItems: 'center',
    justifyContent: 'center',
    backgroundColor: '#281499',
    borderRadius: 12,
    paddingVertical: 16,
    gap: 8,
